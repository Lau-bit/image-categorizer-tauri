{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Image Categorizer",
  "version": "1.0.0",
  "identifier": "com.slaur.image-categorizer",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Image Categorizer",
        "width": 1200,
        "height": 780,
        "minWidth": 780,
        "minHeight": 500,
        "decorations": true,
        "backgroundColor": "#101114",
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self' asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'; img-src 'self' data: asset: http://asset.localhost;",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
